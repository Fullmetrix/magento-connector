<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Event/etc/events.xsd">
    <event name="customer_login">
        <observer name="fullmetrix_customer_login" instance="Fullmetrix\Connector\Observer\CustomerLogin"/>
    </event>
    <event name="checkout_cart_add_product_complete">
        <observer name="fullmetrix_cart_add" instance="Fullmetrix\Connector\Observer\CartAddProduct"/>
    </event>
    <event name="sales_order_place_after">
        <observer name="fullmetrix_order_place" instance="Fullmetrix\Connector\Observer\OrderPlaceAfter"/>
    </event>
</config>
