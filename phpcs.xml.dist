<?xml version="1.0"?>
<ruleset name="FullmetrixConnector">
    <description>Magento coding standard for the Fullmetrix connector, with justified streaming exclusions.</description>
    <rule ref="Magento2"/>
    <rule ref="Magento2.Security.LanguageConstruct.ExitUsage">
        <exclude-pattern>Controller/Api/Stream.php</exclude-pattern>
    </rule>
</ruleset>
